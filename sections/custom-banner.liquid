{{ 'custom-banner.css' | asset_url | stylesheet_tag }}

<section class="custom-banner">
  <div class="cb-topbar">
    <div class="cb-hamburger"><span></span><span></span><span></span></div>
    <div class="cb-logo">{{ section.settings.logo_text }}</div>
    <div class="cb-message">{{ section.settings.top_message }}</div>
    <a href="{{ section.settings.top_button_link }}" class="cb-top-btn">
      {{ section.settings.top_button_text }} <span>→</span>
    </a>
  </div>
  <div class="cb-hero">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'cb-hero-image' }}
    {% endif %}
  </div>
  <div class="cb-content">
    <div class="cb-left">
      <h2>{{ section.settings.heading }}</h2>
            <div class="cb-description cb-desktop-only">
        {{ section.settings.description }}
      </div>
      <div class="cb-description cb-mobile-only">
        {{ section.settings.description_mobile }}
      </div>
            <a href="{{ section.settings.button_link }}" class="cb-button cb-desktop-only">
        {{ section.settings.button_text }} <span>→</span>
      </a>
    </div>

    <div class="cb-right">
      {% if section.settings.side_image != blank %}
        {{ section.settings.side_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'cb-side-image' }}
      {% endif %}
      
      <a href="{{ section.settings.button_link }}" class="cb-button cb-mobile-only">
        {{ section.settings.button_text }} <span>→</span>
      </a>
    </div>
  </div>
  <div class="cb-strip">
    <span class="cb-strip-desktop">{{ section.settings.bottom_text }}</span>
    <span class="cb-strip-mobile">{{ section.settings.bottom_text_mobile }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "TISSO VISION" },
    { "type": "text", "id": "top_message", "label": "Top Message", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "top_button_text", "label": "Top Button Text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "top_button_link", "label": "Top Button Link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Photography (Desktop Only)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { 
      "type": "richtext", 
      "id": "description", 
      "label": "Description (Desktop)", 
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>" 
    },
    { 
      "type": "richtext", 
      "id": "description_mobile", 
      "label": "Description (Mobile)", 
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>" 
    },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "image_picker", "id": "side_image", "label": "Illustration Image" },
    { "type": "text", "id": "bottom_text", "label": "Strip Text (Desktop)", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" },
    { "type": "text", "id": "bottom_text_mobile", "label": "Strip Text (Mobile)", "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR" }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}